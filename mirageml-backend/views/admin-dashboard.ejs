<div class="stats-grid">
    <div class="stat-card" style="border-left-color: #3498db;">
        <div class="stat-icon" style="background: rgba(52, 152, 219, 0.1);">
            <i class="fas fa-users"></i>
        </div>
        <div class="stat-content">
            <h3>Пользователей</h3>
            <div class="value"><%= stats.totalUsers %></div>
            <div class="stat-change positive">
                <i class="fas fa-arrow-up"></i> Активных: <%= stats.userCount %>
            </div>
        </div>
    </div>
    <div class="stat-card" style="border-left-color: #27ae60;">
        <div class="stat-icon" style="background: rgba(39, 174, 96, 0.1);">
            <i class="fas fa-folder"></i>
        </div>
        <div class="stat-content">
            <h3>Проектов</h3>
            <div class="value"><%= stats.totalProjects %></div>
            <div class="stat-change">
                <i class="fas fa-database"></i> Всего создано
            </div>
        </div>
    </div>
    <div class="stat-card" style="border-left-color: #f39c12;">
        <div class="stat-icon" style="background: rgba(243, 156, 18, 0.1);">
            <i class="fas fa-clock"></i>
        </div>
        <div class="stat-content">
            <h3>Сессий</h3>
            <div class="value"><%= stats.totalSessions %></div>
            <div class="stat-change">
                <i class="fas fa-globe"></i> Активных сейчас
            </div>
        </div>
    </div>
    <div class="stat-card" style="border-left-color: #9b59b6;">
        <div class="stat-icon" style="background: rgba(155, 89, 182, 0.1);">
            <i class="fas fa-comments"></i>
        </div>
        <div class="stat-content">
            <h3>Отзывов</h3>
            <div class="value"><%= stats.totalReviews %></div>
            <div class="stat-change positive">
                <i class="fas fa-check"></i> Одобрено: <%= stats.approvedReviews %>
            </div>
        </div>
    </div>
</div>

<div class="charts-grid">
    <div class="card chart-card">
        <div class="card-header">
            <h3><i class="fas fa-chart-pie"></i> Пользователи по ролям</h3>
        </div>
        <canvas id="rolesChart"></canvas>
    </div>

    <div class="card chart-card">
        <div class="card-header">
            <h3><i class="fas fa-chart-pie"></i> Статус отзывов</h3>
        </div>
        <canvas id="reviewsChart"></canvas>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3><i class="fas fa-chart-line"></i> Активность сессий</h3>
    </div>
    <canvas id="sessionsChart" height="80"></canvas>
</div>

<div class="info-grid">
    <div class="card info-card">
        <div class="info-header">
            <i class="fas fa-code" style="color: #667eea;"></i>
            <h4>Разработчики</h4>
        </div>
        <div class="info-value"><%= stats.developerCount %></div>
        <p class="info-desc">Полный доступ к системе</p>
    </div>

    <div class="card info-card">
        <div class="info-header">
            <i class="fas fa-user-shield" style="color: #f5576c;"></i>
            <h4>Модераторы</h4>
        </div>
        <div class="info-value"><%= stats.moderatorCount %></div>
        <p class="info-desc">Ограниченный доступ</p>
    </div>

    <div class="card info-card">
        <div class="info-header">
            <i class="fas fa-shield-alt" style="color: #e74c3c;"></i>
            <h4>Админы</h4>
        </div>
        <div class="info-value"><%= stats.adminCount %></div>
        <p class="info-desc">Пользователей с правами админа</p>
    </div>

    <div class="card info-card">
        <div class="info-header">
            <i class="fas fa-user" style="color: #3498db;"></i>
            <h4>Пользователи</h4>
        </div>
        <div class="info-value"><%= stats.userCount %></div>
        <p class="info-desc">Зарегистрированных пользователей</p>
    </div>

    <div class="card info-card">
        <div class="info-header">
            <i class="fas fa-check-circle" style="color: #27ae60;"></i>
            <h4>Одобренные отзывы</h4>
        </div>
        <div class="info-value"><%= stats.approvedReviews %></div>
        <p class="info-desc">Прошли модерацию</p>
    </div>

    <div class="card info-card">
        <div class="info-header">
            <i class="fas fa-hourglass-half" style="color: #f39c12;"></i>
            <h4>На модерации</h4>
        </div>
        <div class="info-value"><%= stats.pendingReviews %></div>
        <p class="info-desc">Ожидают проверки</p>
    </div>
</div>

<div class="card system-info">
    <div class="card-header">
        <h3><i class="fas fa-info-circle"></i> Информация о системе</h3>
    </div>
    <div class="info-table">
        <div class="info-row">
            <span class="info-label">Версия панели:</span>
            <span class="info-value">MirageML Admin v1.0.0</span>
        </div>
        <div class="info-row">
            <span class="info-label">Порт сервера:</span>
            <span class="info-value"><%= port %></span>
        </div>
        <div class="info-row">
            <span class="info-label">Дата запуска:</span>
            <span class="info-value"><%= new Date().toLocaleDateString('ru-RU') %></span>
        </div>
        <div class="info-row">
            <span class="info-label">Статус:</span>
            <span class="info-value"><span class="status-badge">Работает</span></span>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    const statsData = {
        developerCount: <%= stats.developerCount || 0 %>,
        moderatorCount: <%= stats.moderatorCount || 0 %>,
        adminCount: <%= stats.adminCount || 0 %>,
        userCount: <%= stats.userCount || 0 %>,
        approvedReviews: <%= stats.approvedReviews || 0 %>,
        pendingReviews: <%= stats.pendingReviews || 0 %>,
        totalSessions: <%= stats.totalSessions || 0 %>,
        totalProjects: <%= stats.totalProjects || 0 %>
    };

    const colors = {
        blue: '#3498db',
        green: '#27ae60',
        orange: '#f39c12',
        purple: '#9b59b6',
        red: '#e74c3c',
        teal: '#1abc9c',
        gray: '#95a5a6',
        developer: '#667eea',
        moderator: '#f5576c'
    };

    const rolesCtx = document.getElementById('rolesChart').getContext('2d');
    new Chart(rolesCtx, {
        type: 'doughnut',
        data: {
            labels: ['Разработчики', 'Модераторы', 'Админы', 'Пользователи'],
            datasets: [{
                data: [statsData.developerCount, statsData.moderatorCount, statsData.adminCount, statsData.userCount],
                backgroundColor: [colors.developer, colors.moderator, colors.red, colors.blue],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        padding: 15,
                        font: { size: 12 }
                    }
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            const total = context.dataset.data.reduce((a, b) => a + b, 0);
                            const percent = ((context.raw / total) * 100).toFixed(1);
                            return context.label + ': ' + context.raw + ' (' + percent + '%)';
                        }
                    }
                }
            }
        }
    });

    const reviewsCtx = document.getElementById('reviewsChart').getContext('2d');
    new Chart(reviewsCtx, {
        type: 'doughnut',
        data: {
            labels: ['Одобренные', 'На модерации'],
            datasets: [{
                data: [statsData.approvedReviews, statsData.pendingReviews],
                backgroundColor: [colors.green, colors.orange],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        padding: 15,
                        font: { size: 12 }
                    }
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            const total = context.dataset.data.reduce((a, b) => a + b, 0);
                            const percent = total > 0 ? ((context.raw / total) * 100).toFixed(1) : 0;
                            return context.label + ': ' + context.raw + ' (' + percent + '%)';
                        }
                    }
                }
            }
        }
    });

    const sessionsCtx = document.getElementById('sessionsChart').getContext('2d');
    new Chart(sessionsCtx, {
        type: 'bar',
        data: {
            labels: ['Пользователи', 'Проекты', 'Сессии', 'Отзывы'],
            datasets: [{
                label: 'Количество',
                data: [
                    statsData.userCount + statsData.adminCount,
                    statsData.totalProjects,
                    statsData.totalSessions,
                    statsData.approvedReviews + statsData.pendingReviews
                ],
                backgroundColor: [
                    colors.blue,
                    colors.green,
                    colors.orange,
                    colors.purple
                ],
                borderRadius: 8,
                borderSkipped: false
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    display: false
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: {
                        color: 'rgba(0, 0, 0, 0.05)'
                    },
                    ticks: {
                        precision: 0
                    }
                },
                x: {
                    grid: {
                        display: false
                    }
                }
            }
        }
    });
</script>

<style>
